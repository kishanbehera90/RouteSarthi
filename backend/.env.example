# Copy to .env and fill in. The scaffold runs without any of these.

# Postgres + PostGIS (Step 1)
DATABASE_URL=postgresql+psycopg://routesarthi:routesarthi@localhost:5432/routesarthi

# Redis cache (Step 4)
REDIS_URL=redis://localhost:6379/0

# Real road-routing for first/last-mile legs. Tried as a chain:
# OSRM -> ORS -> Geoapify -> haversine. Set any subset; leave the rest blank.
# Set BOTH ORS and Geoapify to get two independent free quotas — if one hits
# its daily/minute limit, the app fails over to the other automatically.

# OpenRouteService — free, no card/Docker. Sign up at openrouteservice.org
# (~2000 req/day, 40/min). See backend/README.md for the 5-minute steps.
ORS_API_KEY=

# Geoapify — free, no card, email signup at geoapify.com (~3000 req/day).
# Second free routing quota / failover for ORS.
GEOAPIFY_API_KEY=

# Optional, for later: self-hosted OSRM on your own VM (no per-request limits).
# Setting this makes it the primary; ORS/Geoapify stay as the fallback chain.
# See backend/README.md's OSRM section.
OSRM_URL=

# RapidAPI key (IRCTC1, free tier ~10 calls/month - budget-guarded use only)
RAPIDAPI_KEY=

# Auth — required for signup/login to work (any long random string; must be
# IDENTICAL across every server process, so set it explicitly, don't leave blank)
SECRET_KEY=

# Password-reset emails via Brevo's HTTPS API (free tier, 300/day) — NOT raw
# SMTP. Some hosts (e.g. Render's free tier) block outbound SMTP ports
# entirely, so this goes over normal HTTPS instead, which always works.
# BREVO_API_KEY: app.brevo.com -> SMTP & API > API Keys > Generate a new key
#   (this is a DIFFERENT key from the SMTP login/password pair — don't use that one).
# SMTP_FROM_EMAIL: must be verified as a sender in Brevo's dashboard
#   (Senders, Domains & Dedicated IPs > Senders — a confirmation-link click, no
#   DNS/domain needed) before it can send.
# Leave BREVO_API_KEY blank to disable "forgot password" without breaking the
# rest of auth (it logs the reset link instead of emailing it).
BREVO_API_KEY=
SMTP_FROM_EMAIL=

# Where the frontend runs — used to build password-reset links
FRONTEND_URL=http://localhost:5173

# Extra allowed CORS origins for prod, comma-separated (dev origins are always allowed)
CORS_ORIGINS=
