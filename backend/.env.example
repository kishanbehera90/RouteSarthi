# Copy to .env and fill in. The scaffold runs without any of these.

# Postgres + PostGIS (Step 1)
DATABASE_URL=postgresql+psycopg://routesarthi:routesarthi@localhost:5432/routesarthi

# Redis cache (Step 4)
REDIS_URL=redis://localhost:6379/0

# Self-hosted OSRM for first/last-mile road legs (Step 1)
OSRM_URL=http://localhost:5000

# RapidAPI key (IRCTC1, free tier ~10 calls/month - budget-guarded use only)
RAPIDAPI_KEY=
