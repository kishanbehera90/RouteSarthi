# Copy to .env and fill in. The scaffold runs without any of these.

# Postgres + PostGIS (Step 1)
DATABASE_URL=postgresql+psycopg://routesarthi:routesarthi@localhost:5432/routesarthi

# Redis cache (Step 4)
REDIS_URL=redis://localhost:6379/0

# Real road-routing for first/last-mile legs (Step 1). OpenRouteService is
# the default — sign up free at openrouteservice.org, no card/Docker needed.
# See backend/README.md for the 5-minute signup steps.
ORS_API_KEY=

# Optional, for later: self-hosted OSRM on your own VM (no per-request
# limits). Setting this alone switches the app to OSRM — no code changes,
# and it takes priority over ORS_API_KEY if both are set. See
# backend/README.md's OSRM section.
OSRM_URL=

# RapidAPI key (IRCTC1, free tier ~10 calls/month - budget-guarded use only)
RAPIDAPI_KEY=

# Auth — required for signup/login to work (any long random string; must be
# IDENTICAL across every server process, so set it explicitly, don't leave blank)
SECRET_KEY=

# SMTP (password-reset emails) — Brevo's free tier (300/day). Get credentials
# at app.brevo.com under SMTP & API > SMTP: SMTP_USER is your Brevo account
# login email, SMTP_PASSWORD is the generated SMTP key (not your account
# password). SMTP_FROM_EMAIL must be verified as a sender in Brevo's dashboard
# (Senders, Domains & Dedicated IPs > Senders — a confirmation-link click, no
# DNS/domain needed) before it can send. Leave SMTP_USER blank to disable
# "forgot password" without breaking the rest of auth.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# Where the frontend runs — used to build password-reset links
FRONTEND_URL=http://localhost:5173

# Extra allowed CORS origins for prod, comma-separated (dev origins are always allowed)
CORS_ORIGINS=
